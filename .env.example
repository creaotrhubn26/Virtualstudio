# AI environment planning
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# Photoreal character generation roadmap
# Recommended split:
# - hero characters: Didimo
# - branded staff / NPCs: Avaturn
# - optional fast phone-scan path: in3D
CHARACTER_PROVIDER_HERO=didimo
CHARACTER_PROVIDER_STAFF=avaturn
CHARACTER_PROVIDER_SCAN=in3d
CHARACTER_PROVIDER_FALLBACK=local

# Didimo
DIDIMO_API_KEY=
DIDIMO_API_BASE_URL=https://api.didimo.co
DIDIMO_GENERATE_URL=
DIDIMO_HEALTH_URL=
DIDIMO_UPLOAD_FIELD=photo
DIDIMO_DEPTH_FIELD=depth
DIDIMO_RESULT_NAME=gltf
DIDIMO_POLL_INTERVAL_SECONDS=3
DIDIMO_TIMEOUT_SECONDS=240

# Avaturn
AVATURN_API_TOKEN=
AVATURN_API_BASE_URL=https://api.avaturn.me
AVATURN_GENERATE_URL=
AVATURN_HEALTH_URL=
AVATURN_AUTH_HEADER=Authorization
AVATURN_AUTH_TOKEN=

# in3D
IN3D_API_TOKEN=
IN3D_API_BASE_URL=https://api.developer.in3d.io
IN3D_GENERATE_URL=
IN3D_HEALTH_URL=
IN3D_AUTH_HEADER=Authorization
IN3D_AUTH_TOKEN=

ENV_LAYOUT_PROVIDER=auto
ENV_LAYOUT_MAX_IMAGES=3
ENV_LAYOUT_MAX_DIMENSION=512
ENV_LAYOUT_SEGMENTATION_PROMPT_LIMIT=12
ENV_LAYOUT_TIMEOUT_SECONDS=20
ENV_LAYOUT_CACHE_TTL_SECONDS=120
ENV_LAYOUT_EXTERNAL_AUTH_HEADER=Authorization
ENV_LAYOUT_EXTERNAL_AUTH_TOKEN=
# Optional external image->layout providers
# Both endpoints receive:
# {
#   "referenceImages": ["data:image/..."],
#   "prompt": "...",
#   "preferredRoomType": "storefront|interior_room|...",
#   "segmentationPrompts": ["floor", "door", "counter", ...],
#   "layoutOptions": { ... }
# }
# SAM2 should return segmentation-style planes/objects/masks.
# Depth should return depthProfile / estimatedShell / suggestedCamera style signals.
ENV_LAYOUT_EXTERNAL_URL=internal://gemini_layout
ENV_LAYOUT_SAM2_URL=
ENV_LAYOUT_DEPTH_URL=
ENV_LAYOUT_SAM2_AUTH_HEADER=Authorization
ENV_LAYOUT_SAM2_AUTH_TOKEN=
ENV_LAYOUT_DEPTH_AUTH_HEADER=Authorization
ENV_LAYOUT_DEPTH_AUTH_TOKEN=
ENV_LAYOUT_EXTERNAL_HEALTH_URL=
ENV_LAYOUT_SAM2_HEALTH_URL=
ENV_LAYOUT_DEPTH_HEALTH_URL=

# Optional preview/VLM-backed environment evaluation
ENV_VALIDATION_PROVIDER=auto
ENV_VALIDATION_TIMEOUT_SECONDS=20
ENV_VALIDATION_CACHE_TTL_SECONDS=120
ENV_VALIDATION_EXTERNAL_URL=internal://gemini_validation
ENV_VALIDATION_EXTERNAL_HEALTH_URL=
ENV_VALIDATION_EXTERNAL_AUTH_HEADER=Authorization
ENV_VALIDATION_EXTERNAL_AUTH_TOKEN=

# Cloudflare R2 large-file storage
CLOUDFLARE_R2_ACCESS_KEY_ID=replace_with_your_r2_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace_with_your_r2_secret
R2_PUBLIC_BASE_URL=https://pub-casting.r2.dev
R2_LARGE_FILE_STORAGE_ENABLED=true
R2_DELETE_LOCAL_AFTER_UPLOAD=true
R2_GENERATED_ASSET_BUCKET=casting-assets
R2_GENERATED_ASSET_PUBLIC_BASE_URL=https://pub-casting.r2.dev
R2_GENERATED_ASSET_PREFIX=generated-assets
R2_LARGE_FILE_SYNC_MIN_BYTES=524288
R2_LARGE_FILE_SYNC_ROOTS=backend/test_images,backend/outputs,backend/backend/outputs,backend/humaniflow/assets,backend/humaniflow/model_files,backend/sam3d_repo/assets,backend/sam3d_repo/notebook/images,backend/facexformer_repo/docs/static/images,attached_assets,public
STUDIO_THUMBNAIL_INLINE_MAX_CHARS=120000
STUDIO_STORAGE_MAX_UPLOAD_BYTES=26214400
