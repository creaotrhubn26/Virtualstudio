# =============================================================================
# Virtual Studio — environment variables
# Copy to .env (or .env.local) and fill in values. Never commit secrets.
# =============================================================================

# ---- CORS (backend) ---------------------------------------------------------
# Comma-separated list of origins allowed to call the FastAPI backend.
# Must NOT be "*" when cookies/credentials are in use.
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ---- Postgres (backend) -----------------------------------------------------
# Used by every *_service.py module in backend/.
DATABASE_URL=postgresql://user:password@localhost:5432/virtualstudio

# ---- Cloudflare R2 (backend + dev proxy) -----------------------------------
CLOUDFLARE_R2_ACCESS_KEY_ID=replace_me
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace_me
# Optional legacy aliases (backend accepts either pair):
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=https://pub-casting.r2.dev

# ---- AI bootstrap: Claude (Scene Director + Vision) ------------------------
# Primary AI engine for Scene Director. With this set, Claude handles mood
# inference, rich environment prompt enrichment, and Claude Vision analysis
# of reference images (user uploads a film still or painting → Claude reads
# its lighting/mood/composition and biases director decisions).
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_DIRECTOR_MODEL=claude-opus-4-7
CLAUDE_VISION_MODEL=claude-sonnet-4-6

# ---- AI: Gemini (environment planner legacy) ------------------------------
# Still used by environment_planner_service for backwards compatibility.
# Will be phased out in favor of Claude once the environment-planner Claude
# migration lands.
GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
# Optional alias accepted by backend:
# GOOGLE_API_KEY=

# ---- AI: Replicate (FLUX image gen + TripoSR/Trellis 3D) ------------------
# Replicate is now the primary image-gen provider (replacing OpenAI
# gpt-image-1 in storyboard_image_service) and the primary cloud 3D
# provider (TripoSR, Trellis).
REPLICATE_API_TOKEN=
# Optional — default text-to-image model. Choices:
#   flux-schnell  (default, ~2-4 s)
#   flux-dev      (10-20 s, higher quality)
#   flux-1.1-pro  (10-30 s, top quality)
REPLICATE_FLUX_MODEL=flux-schnell

# ---- AI: OpenAI (DEPRECATED — only legacy ai_director_service reads it) ---
# Scene Director, storyboard images, and character casting have been
# migrated to Anthropic + Replicate. The only service still reading these
# is backend/ai_director_service.py which is scheduled for Claude
# tool-use migration. Leave blank unless you need the legacy AI director.
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
OPENAI_API_KEY=

# ---- AI: MeshyAI (optional alternative 3D-gen, not wired in yet) ---------
# Placeholder for future MeshyAI integration as a sibling to TripoSR/Trellis.
MESHY_API_KEY=

# ---- Multi-bucket R2 (backend reads this list when present) --------------
# Comma-separated list of ML model buckets. Lookups fall through in order.
# First entry is the default bucket for uploads.
CLOUDFLARE_R2_MODELS_BUCKETS=ml-models
# Account id is used to build the endpoint URL; falls back to historical
# hardcoded account when unset.
CLOUDFLARE_R2_ACCOUNT_ID=

# ---- AI: Rodin (3D generation) ---------------------------------------------
RODIN_API_KEY=

# ---- Hugging Face (FLUX model download) ------------------------------------
HUGGING_FACE_HUB_TOKEN=
# Alias:
# HF_TOKEN=

# ---- Asset providers --------------------------------------------------------
SKETCHFAB_API_TOKEN=
POLYPIZZA_API_KEY=
FREESOUND_API_KEY=

# ---- Feature flags (backend) -----------------------------------------------
ENABLE_FLUX=true
ENABLE_DECA=true

# ---- SAM 3D model paths (backend/sam3d) ------------------------------------
SAM3D_MHR_PATH=
SAM3D_DETECTOR_PATH=
SAM3D_SEGMENTOR_PATH=
SAM3D_FOV_PATH=

# ---- Frontend (Vite) -------------------------------------------------------
# Rotate this upstream — the old token was leaked in git history.
VITE_BLENDERKIT_API_KEY=
# Controls whether the frontend reads assets via /r2-assets/ proxy or direct:
VITE_USE_R2_ASSETS=true
# Only used if the frontend talks to the database directly (rare):
# VITE_DATABASE_URL=

# ---- E2E tests (playwright) ------------------------------------------------
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
# PLAYWRIGHT_HEADLESS=1
# PLAYWRIGHT_MANAGED_SERVER=1
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
